# Copy this file to .env and fill in your values.

# Local artifacts. Override DB_URL with postgresql://... when needed.
DB_URL=sqlite:///out/ads.db
CAPTURES_DIR=out/captures

# ── Logging ────────────────────────────────────────────────────────────────
# AD_RESEARCH_LOG_LEVEL=DEBUG|INFO|WARNING|ERROR (default: INFO)
# DEBUG shows full diagnostic output including mitmdump commands, API calls, etc.
# INFO shows start/stop events, errors, warnings (recommended for normal runs)
# WARNING and ERROR show only problems
AD_RESEARCH_LOG_LEVEL=INFO

# ── Proxy mode ─────────────────────────────────────────────────────────────
# residential   three external residential endpoints (robustness/generalization)
# local         two local mitmdump instances started automatically
# socks5        two SOCKS5 endpoints  →  set PROXY_POOR / PROXY_RICH below
# upstream      two external HTTP proxies  →  set PROXY_POOR / PROXY_RICH
# upstream_mitm local mitmdump chained through UPSTREAM_PROXY for real egress
PROXY_MODE=local

# ── Local mitmdump ports (PROXY_MODE=local or upstream_mitm) ───────────────
PROXY_POOR_PORT=8181
PROXY_RICH_PORT=8182

# ── Upstream proxy chain (PROXY_MODE=upstream_mitm) ───────────────────────
# Single upstream whose egress IP represents "both" conditions.
# For true geo-separation you need two different endpoints.
# UPSTREAM_PROXY=socks5://127.0.0.1:1080

# ── External proxy endpoints (PROXY_MODE=socks5 or upstream) ──────────────
# Format: socks5://host:port  OR  http://user:pass@host:port
# PROXY_POOR=socks5://127.0.0.1:1080
# PROXY_RICH=socks5://127.0.0.1:1081

# ── Residential proxies (PROXY_MODE=residential) ─────────────────────────
# Three stable endpoints (preferred: keep them stable across trials).
# PROXY_RESIDENTIAL_1=http://user:pass@host:port
# PROXY_RESIDENTIAL_2=http://user:pass@host:port
# PROXY_RESIDENTIAL_3=http://user:pass@host:port
# Optional reporting metadata (JSON dict; do not include secrets):
# PROXY_IDENTITY_META_JSON={"res_1":{"city":"?"},"res_2":{},"res_3":{}}

# ── Screenshot API (optional, for screenshot captures) ──────────────────
# Base64-encoded "user:password" for Screenshot API
# DECODO_SCRAPER_AUTH=Basic <base64_encoded_credentials>

# ── Capture / telemetry ─────────────────────────────────────────────────
# Captures
CAPTURE_SCREENSHOTS=1
CAPTURE_DOM_SNIPPETS=0

# Diagnostics: per-navigation status, redirects, cookie count, and errors
ENABLE_TELEMETRY=0
# SENTRY_MONITOR_FAILURE_ISSUE_THRESHOLD=1
# SENTRY_MONITOR_RECOVERY_THRESHOLD=1
# SENTRY_MONITOR_OWNER=team:6

# Google Search measurement
ENABLE_GOOGLE_SEARCH_MEASUREMENT=1
QUERIES_PER_TOPIC_PER_TRIAL=1

# Measurement-site rotation
# Stratified deterministic sampling from a representative web slice.
# Override per stratum if needed; values may be comma- or newline-separated.
# AD_SITE_POOL_NEWS=https://www.nu.nl,https://www.trouw.nl,https://www.volkskrant.nl
# AD_SITE_POOL_COMMERCE=https://www.bol.com,https://www.coolblue.nl,https://www.marktplaats.nl
# AD_SITE_POOL_REGIONAL=https://www.omroepbrabant.nl,https://www.rijnmond.nl
# AD_SITE_POOL_UTILITY=https://www.rijksoverheid.nl,https://www.kvk.nl,https://www.postnl.nl,https://www.ns.nl
# AD_SITE_POOL_NICHE=https://www.techpulse.nl,https://www.emerce.nl,https://www.zorgvisie.nl
# Number of measurement sites to use per trial. Defaults to 10.
# Sampling stays balanced across strata while rotating deterministically by trial id.
# MEASUREMENT_SITES_PER_TRIAL=10
